# ─── Server ───────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── MongoDB ──────────────────────────────────────
MONGO_URI=mongodb://localhost:27017/edu-platform

# ─── JWT ──────────────────────────────────────────
JWT_SECRET=
JWT_EXPIRE=7d

# ─── Email (Google OAuth2 API) ────────────────────
SMTP_USER=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
FROM_EMAIL=noreply@eduplatform.com
FROM_NAME=EduPlatform

# ─── Cloudinary (Optional) ───────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ─── Google Gemini API ────────────────────────────
GEMINI_API_KEY=


# ─── Client URL ──────────────────────────────────
CLIENT_URL=http://localhost:5173

# ─── Google OAuth (Future) ────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── GitHub OAuth (Future) ────────────────────────
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
